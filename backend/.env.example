OPENROUTER_API_KEY=sk-or-...
GIT_TOKEN=ghp_...
ABUSEIPDB_API_KEY=your_key_here
NVD_API_KEY=your_key_here

# Trivy CVE scanning (Docker Scanner agent)
# Install: backend/scripts/install-trivy.sh
TRIVY_PATH=.bin/trivy
TRIVY_CACHE_DIR=.trivy-cache
TRIVY_WARMUP=true
TRIVY_SKIP_DB_UPDATE=false
TRIVY_SEVERITIES=CRITICAL,HIGH,MEDIUM
TRIVY_MAX_CVES=25
TRIVY_TIMEOUT_SEC=180
