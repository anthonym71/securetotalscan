# ──────────────────────────────────────────────────────────────
# Secure Total Scan (web) — environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit real secrets. .env.local is gitignored.
# Backend env vars live in /backend/.env.example
# ──────────────────────────────────────────────────────────────

# Public URL of the agent backend (FastAPI on Railway).
# Local dev default is http://localhost:8000.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: email the PDF report to the user after a scan.
# Get a key at https://resend.com (free tier available).
RESEND_API_KEY=YOUR_RESEND_API_KEY
REPORT_FROM_EMAIL=reports@securetotalscan.com

# Optional: simple per-IP rate limiting via Upstash Redis.
# Leave blank to disable rate limiting (fine for local/dev).
UPSTASH_REDIS_REST_URL=YOUR_UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REDIS_REST_TOKEN

# Free surface-scan tuning.
SCAN_MAX_BUNDLES=8
SCAN_FETCH_TIMEOUT_MS=8000

# GoHighLevel (LeadConnector) v2 API — powers /api/lead lead capture.
# GHL → Settings → Private Integrations → create a token with contacts.write.
# Server-side only; never exposed to the client.
GHL_API_TOKEN=YOUR_GHL_PRIVATE_INTEGRATION_TOKEN
GHL_LOCATION_ID=YOUR_GHL_LOCATION_ID
